# AttestRWA environment — copy to `.env` and customize.
# Legacy `BANKABLE_*` names still work as aliases (see apps/api/src/app/config.py).

ATTESTRWA_ENV=development
ATTESTRWA_API_HOST=0.0.0.0
ATTESTRWA_API_PORT=8080
ATTESTRWA_API_VERSION=1.0.0
ATTESTRWA_LOG_LEVEL=INFO
ATTESTRWA_CORS_ORIGINS=https://scanovich.ai,https://www.scanovich.ai,http://localhost:3000

NEXT_PUBLIC_ATTESTRWA_API_URL=http://localhost:8080
# Legacy web env (still supported in archive/v0.5 panels):
NEXT_PUBLIC_BANKABLE_API_URL=http://localhost:8080
NEXT_PUBLIC_SEABW_API_URL=http://localhost:8080

# --- AttestRWA v1 — on-chain layer ---
# Spin up the local dev chain with: ./scripts/dev-chain.sh
# It writes runtime values into `.dev-chain.state` (gitignored).
#
# Dev mode (Anvil fork of Base Sepolia):
DEV_RPC_URL=http://127.0.0.1:8545
DEV_CHAIN_ID=84532
DEV_FORK_URL=https://sepolia.base.org

# Canonical EAS protocol addresses — identical on Base mainnet, Base
# Sepolia, Optimism, and the local fork. See https://docs.attest.org
EAS_ADDRESS=0x4200000000000000000000000000000000000021
EAS_SCHEMA_REGISTRY_ADDRESS=0x4200000000000000000000000000000000000020

# SettlementApproval schema UID — deterministic for the canonical schema
# string + zero resolver + revocable=true. Same on dev fork and real
# Base Sepolia.
EAS_SCHEMA_UID_SETTLEMENT_APPROVAL=0x1f64ec96216b0381dc4443b7378c57485f2217656537e8ea36f0b23af047cc96

# Dev attester EOA = Anvil default account #0.
# THIS IS A PUBLICLY KNOWN TEST KEY. DO NOT USE IT ON ANY REAL NETWORK.
ATTESTER_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
ATTESTER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Contract addresses on the dev fork (deterministic for the same deployer
# nonce sequence). Re-run scripts/deploy-contracts.sh to refresh.
MOCK_USDC_ADDRESS=0xeba5CEc9257045Df0B44eA784F9a7Fa07DeeF6d4
SETTLEMENT_ESCROW_ADDRESS=0x54D4962847bf85AB71a1Fc984510dc12D3feA1D8

# Policy pack (optional — default: data/synthetic/policies/default_attestrwa_policy.yaml)
# ATTESTRWA_POLICY_FILE=data/policies/asean-property-settlement-v1.yaml

# Wallet taint provider: mock (default) | chainalysis_stub
# ATTESTRWA_TAINT_PROVIDER=mock
# ATTESTRWA_CHAINALYSIS_API_KEY=your-chainalysis-api-key

# Production mode (real Base Sepolia — opt-in):
# PROD_RPC_URL=https://sepolia.base.org
# Generate a fresh attester wallet (`cast wallet new`), fund via
# https://www.alchemy.com/faucets/base-sepolia, then put values in `.env`
# (NOT `.env.example`). Never reuse the dev test key on a real network.
# PROD_ATTESTER_ADDRESS=
# PROD_ATTESTER_PRIVATE_KEY=

# --- Demo / local contour (hackathon) ---
ATTESTRWA_AI_TIER=demo_local
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=attestrwa
LOCAL_AI_EMBEDDING_BASE_URL=http://localhost:9001
LOCAL_AI_RERANKER_BASE_URL=http://localhost:9002
LOCAL_AI_LLM_INSTRUCT_BASE_URL=http://localhost:1234/v1
LOCAL_AI_LLM_INSTRUCT_MODEL=local-model
LOCAL_AI_LLM_ENABLE_THINKING=false
CONSULT_RETRIEVAL_MODE=auto

LOCAL_AI_EMBEDDING_TIMEOUT=30
LOCAL_AI_RERANKER_TIMEOUT=30
LOCAL_AI_LLM_INSTRUCT_TIMEOUT=600

# --- archive/v0.5 only (WhatsApp booth demo — not used by AttestRWA v1) ---
# WHATSAPP_BRIDGE_ADDR=:8020
# WHATSAPP_SESSION_PATH=./whatsapp_session/whatsapp.db
