BANKABLE_ENV=development
BANKABLE_API_HOST=0.0.0.0
BANKABLE_API_PORT=8080
BANKABLE_API_VERSION=0.5.5
BANKABLE_LOG_LEVEL=INFO
BANKABLE_CORS_ORIGINS=https://scanovich.ai,https://www.scanovich.ai,http://localhost:3000

NEXT_PUBLIC_BANKABLE_API_URL=http://localhost:8080
NEXT_PUBLIC_SEABW_API_URL=http://localhost:8080

# --- Demo / local contour (hackathon) ---
# See docs/LOCAL_AI_CONTOUR.md and docs/AI_SERVICE_TIERS.md
BANKABLE_AI_TIER=demo_local
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_PREFIX=bankable_property_os
LOCAL_AI_EMBEDDING_BASE_URL=http://localhost:9001
LOCAL_AI_RERANKER_BASE_URL=http://localhost:9002
LOCAL_AI_LLM_INSTRUCT_BASE_URL=http://localhost:1234/v1

# --- Production / enterprise (do not use LM Studio at scale) ---
# LOCAL_AI_LLM_INSTRUCT_BASE_URL=https://your-vllm-gateway.example/v1
# LOCAL_AI_EMBEDDING_BASE_URL=https://your-qwen-embedding.example
# Use vLLM for high concurrency; Qwen-class embeddings for commercial RAG quality.

LOCAL_AI_EMBEDDING_TIMEOUT=30
LOCAL_AI_RERANKER_TIMEOUT=30
LOCAL_AI_LLM_INSTRUCT_TIMEOUT=600
