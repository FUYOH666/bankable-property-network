{
  "filter_paths": "lib/",
  "exclude_informational": false,
  "exclude_low": false,
  "exclude_medium": false,
  "exclude_high": false,
  "solc_remaps": [
    "@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/",
    "@eas/=lib/eas-contracts/contracts/",
    "forge-std/=lib/forge-std/src/"
  ],
  "fail_on": "medium",
  "exclude_dependencies": true
}
